<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8">
    <title>MentorHub Inquiry Received</title>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;600;800&display=swap');
        
        body { 
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif; 
            background-color: #f4faff; 
            margin: 0; 
            padding: 40px 20px; 
            -webkit-font-smoothing: antialiased;
        }
        
        .container { 
            max-width: 600px; 
            margin: 0 auto; 
            background: #ffffff; 
            border-radius: 24px; 
            overflow: hidden;
            box-shadow: 0 10px 25px rgba(6, 182, 212, 0.1); 
            border: 1px solid #cffafe;
        }

        .header { 
            background: linear-gradient(135deg, #0ea5e9 0%, #06b6d4 100%); 
            padding: 40px 30px; 
            text-align: center; 
        }

        .header h1 { 
            color: #ffffff; 
            font-size: 28px; 
            font-weight: 800; 
            letter-spacing: -0.5px;
            margin: 0; 
        }
        
        .content {
            padding: 40px 30px;
            color: #334155;
            font-size: 16px;
            line-height: 1.6;
        }

        .greeting {
            font-size: 20px;
            font-weight: 600;
            color: #0f172a;
            margin-bottom: 20px;
        }

        .message-box { 
            background: #f8fafc; 
            padding: 24px; 
            border-left: 4px solid #06b6d4; 
            border-radius: 0 12px 12px 0; 
            color: #475569;
            margin: 30px 0;
            font-style: italic;
        }

        .message-box-title {
            font-weight: 600;
            color: #0ea5e9;
            margin-bottom: 8px;
            font-style: normal;
            font-size: 14px;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .button-wrap {
            text-align: center;
            margin: 40px 0 20px;
        }

        .button {
            display: inline-block;
            background-color: #06b6d4;
            color: #ffffff;
            text-decoration: none;
            padding: 14px 28px;
            border-radius: 50px;
            font-weight: 600;
            font-size: 16px;
        }

        .footer { 
            padding: 30px;
            font-size: 13px; 
            color: #94a3b8; 
            text-align: center; 
            background-color: #f8fafc;
            border-top: 1px solid #f1f5f9;
        }
        
        .footer span {
            color: #06b6d4;
            font-weight: 600;
        }
    </style>
</head>
<body>
    <div class="container">
        <!-- Header area with premium gradient -->
        <div class="header">
            <h1>mentorhub.</h1>
        </div>
        
        <!-- Main body content -->
        <div class="content">
            <div class="greeting">Hi <%= firstName %>,</div>
            
            <p>Thank you for reaching out to us! This is an automated confirmation to let you know that we have received your message.</p>
            <p>Our team is reviewing your inquiry and will get back to you at <strong><%= email %></strong> within the next 24 hours.</p>
            
            <!-- Original Message Preview -->
            <div class="message-box">
                <div class="message-box-title">Your Message</div>
                "<%= message %>"
            </div>

            <p>If you need immediate assistance regarding your tutoring sessions, please log into your dashboard and chat with your mentor directly.</p>

            <div class="button-wrap">
                <a href="http://localhost:3000/dashboard" class="button">Go to Dashboard</a>
            </div>

            <p style="margin-top: 30px; margin-bottom: 0;">Warm regards,</p>
            <p style="font-weight: 600; margin-top: 5px; color: #0ea5e9;">The MentorHub Team</p>
        </div>

        <!-- Footer -->
        <div class="footer">
            &copy; <%= new Date().getFullYear() %> MentorHub Inc. All rights reserved.<br>
            <br>
            You are receiving this email because you submitted a contact request on our platform.
        </div>
    </div>
</body>
</html>
